{
  "name": "ai-docs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/dist/main.mjs",
  "scripts": {
    "dev": "bun run dev:server & bun run dev:client",
    "dev:server": "bun run --hot server/index.ts",
    "dev:client": "cd client && bun run dev",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "test": "bun test",
    "mcp": "bun run server/lib/mcp/server.ts",
    "build:client": "cd client && npx vite build",
    "build:electron": "node scripts/build-electron.mjs",
    "dev:electron": "npm run build:client && npm run build:electron && electron electron/dist/main.mjs",
    "package": "npm run build:client && npm run build:electron && electron-builder"
  },
  "workspaces": ["client"],
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@resvg/resvg-js": "^2.6.2",
    "better-sqlite3": "^12.6.2",
    "docx": "^9.6.1",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.7.0",
    "jsdom": "24.1.3",
    "katex": "^0.16.40",
    "mathjax-full": "^3.2.2",
    "nanoid": "^5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.2.0",
    "@types/jsdom": "21.1.7",
    "drizzle-kit": "^0.30.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0"
  }
}
